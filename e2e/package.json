    "@opentelemetry/sdk-trace-base": ">=1.9.0",
    "@types/node": "^20.10.5",
    "braintrust": "workspace:^",
    "tsx": "^4.21.0",
    "typescript": "5.4.4",
    "vitest": "^4.1.0",
    "zod": "4.3.6"
  }
}
