{
  "workspaces": {
    "e2e": {
      "entry": [
        "package.json",
        "vitest.config.mts",
        "helpers/**/*.ts",
        "scenarios/**/*.test.ts",
        "scenarios/**/package.json",
        "scenarios/**/*.ts",
        "scenarios/**/*.mjs"
      ],
      "project": [
        "helpers/**/*.ts",
        "scenarios/**/*.test.ts",
        "scenarios/**/package.json",
        "scenarios/**/*.ts",
        "scenarios/**/*.mjs"
      ],
      "ignoreDependencies": ["openai", "openai-v4", "openai-v5"]
    }
  }
}
