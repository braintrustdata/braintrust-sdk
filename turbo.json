{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "OPENAI_API_KEY",
    "OPENAI_BASE_URL",
    "ANTHROPIC_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": []
    },
    "test": {
      "env": [
        "ANTHROPIC_API_KEY",
        "BRAINTRUST_API_KEY",
        "OPENAI_API_KEY",
        "OPENAI_BASE_URL"
      ],
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e": {
      "env": [
        "ANTHROPIC_API_KEY",
        "BRAINTRUST_API_KEY",
        "OPENAI_API_KEY",
        "OPENAI_BASE_URL"
      ],
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:e2e:update": {
      "env": [
        "ANTHROPIC_API_KEY",
        "BRAINTRUST_API_KEY",
        "OPENAI_API_KEY",
        "OPENAI_BASE_URL"
      ],
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "fix:eslint": {
      "outputs": []
    },
    "dev": {
      "cache": false
    },
    "start": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "watch": {},
    "playground": {
      "cache": false,
      "passThroughEnv": [
        "ANTHROPIC_API_KEY",
        "BRAINTRUST_API_KEY",
        "OPENAI_API_KEY"
      ],
      "dependsOn": ["^build", "build"]
    }
  }
}
